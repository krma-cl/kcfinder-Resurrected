{
    "name": "devcrh/kcfinder-resurrected",
    "description": "A maintained, security-focused continuation of KCFinder for modern production environments",
    "type": "project",
    "license": [
        "GPL-3.0-or-later",
        "LGPL-3.0-or-later"
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "KCFinder\\": "src/"
        }
    },
    "scripts": {
        "lint": "@php tools/lint.php",
        "phpunit": "phpunit --configuration phpunit.xml.dist",
        "phpstan": "phpstan analyse --configuration phpstan.neon --no-progress",
        "test": [
            "@lint",
            "@phpunit",
            "@phpstan"
        ]
    },
    "config": {
        "allow-plugins": {},
        "sort-packages": true
    }
}
